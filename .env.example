# ============================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO
# ============================================
# Copia este archivo a .env y completa los valores

# --- API KEYS (CRÍTICO: Mantener privado) ---
GOOGLE_API_KEY=your-google-api-key-here
OLLAMA_BASE_URL=http://localhost:11434

# --- CONFIGURACIÓN DE MODELOS ---
# Ollama (Local - Recomendado)
OLLAMA_MODEL=mistral-nemo

# Google Gemini (Fallback)
GEMINI_MODEL=gemini-1.5-flash

# --- PARÁMETROS DE FUNCIONAMIENTO ---
# Temperatura para respuestas creativas (0.1=preciso, 1.0=creativo)
LLM_TEMPERATURE_VENDEDOR=0.7
LLM_TEMPERATURE_AUDITOR=0.1

# Contexto máximo (tokens)
LLM_NUM_CTX=4096

# --- HISTORIAL Y MEMORIA ---
# Máximo número de mensajes en contexto
MAX_CONTEXT_MESSAGES=10

# Tamaño máximo de historial (caracteres)
MAX_HISTORIAL_LENGTH=5000

# --- BASE DE DATOS ---
DATABASE_PATH=logs/chats.db

# --- LOGGING ---
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=oficina.log

# --- TIMEOUTS ---
OLLAMA_TIMEOUT_SECONDS=10
GOOGLE_TIMEOUT_SECONDS=30

# --- NEGOCIO ---
CAPACIDAD_MAXIMA=11
MINIMO_NOCHES=2
TARIFA_TEMPORADA_BAJA=3500
TARIFA_TEMPORADA_ALTA=4500

# --- DEBUG ---
VERBOSE_MODE=True
ENABLE_METRICS=True
